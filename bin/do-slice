#!/usr/bin/env python3
#
# do-slice PATH START?:END?
#
# Slice PATH by path components using Python-style START:END indexes.

import os
import sys

USAGE = """\
Usage: do-slice PATH START?:END?

Slice PATH by path components using Python-style START:END indexes.

Examples:
  do-slice /a/b/c/d 1:3    -> a/b
  do-slice /a/b/c/d :2     -> /a
  do-slice /a/b/c/d 2:     -> b/c/d
  do-slice a/b/c/d 1:-1    -> b/c

Notes:
  - PATH is split on directory boundaries.
  - Absolute paths keep '/' only when the slice includes the root component.
  - Empty relative slices print '.'; empty absolute slices print '/'.
"""


def parse_slice(text):
    if ":" not in text:
        raise ValueError("slice must be in START:END form")

    start_text, end_text = text.split(":", 1)

    def parse_index(value):
        if value == "":
            return None
        return int(value)

    return slice(parse_index(start_text), parse_index(end_text))


def slice_path(path, slice_text):
    path = os.path.normpath(path)

    if path == os.sep:
        parts = [os.sep]
    elif os.path.isabs(path):
        stripped = path[len(os.sep) :]
        parts = [os.sep] + ([p for p in stripped.split(os.sep) if p] if stripped else [])
    else:
        parts = [p for p in path.split(os.sep) if p]

    sliced = parts[parse_slice(slice_text)]

    if not sliced:
        return os.sep if os.path.isabs(path) else "."

    if sliced[0] == os.sep:
        if len(sliced) == 1:
            return os.sep
        return os.sep + os.path.join(*sliced[1:])

    return os.path.join(*sliced)


def main():
    args = sys.argv[1:]

    if len(args) != 2 or args[0] in ("-h", "--help"):
        print(USAGE)
        sys.exit(0 if args and args[0] in ("-h", "--help") else 1)

    path, slice_text = args

    try:
        print(slice_path(path, slice_text))
    except ValueError as exc:
        sys.stderr.write(f"[!] {exc}\n")
        sys.exit(1)


if __name__ == "__main__":
    main()

